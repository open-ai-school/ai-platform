# ===========================================
# Open AI School — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
#
# cp .env.example .env.local

# --- Authentication (optional — GitHub OAuth) ---
# Create an OAuth app at: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Deployment ---
# Automatically set by Vercel; override for local dev
# NEXTAUTH_URL=http://localhost:3000

# --- Chat Assistant (Edu Bot) ---
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Database (Neon Postgres) ---
# Get your connection string from: https://neon.tech
DATABASE_URL=

# --- Stripe (Payments) ---
# Create your Stripe account at: https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs — create these in Stripe Dashboard > Products
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_LIFETIME=
